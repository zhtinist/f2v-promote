# Application
APP_PORT=:8000
APP_NAME=f2v-promote
DEBUG=true

# MySQL (local docker-compose defaults)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=f2v_dev_123
MYSQL_DATABASE=f2v_promote

# Auth / Session
SESSION_SECRET=change-me-to-a-random-string
ADMIN_TOKEN=
MAX_USERS=50

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=
OPENAI_MAX_RETRIES=3
OPENAI_RETRY_DELAY=2

# Tag generation
TAG_GROUP_COUNT=1
TAG_CATEGORY_COUNT=5

# Zhuge (WeChat Channels promotion platform)
ZHUGE_API_BASE=https://zhuge-login.example.com
ZHUGE_LOGIN_URL=https://zhuge-api.example.com
ZHUGE_ACCOUNT=
ZHUGE_PASSWORD=
ZHUGE_TS_USER_ID=
ZHUGE_WEI_DOU=500
ZHUGE_PLAN_INTERVAL=10
ZHUGE_MAX_PLANS_PER_5MIN=5
ZHUGE_TOKEN_REFRESH_HOURS=20
ZHUGE_PAYMENT_TIMEOUT_HOURS=2
ZHUGE_GROUP_ID=

# Aliyun OSS
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=
OSS_BUCKET=
OSS_DOMAIN=

# Notification
WEBHOOK_URL=

# Logging
LOG_DIR=logs
LOG_LEVEL=INFO

# Optional HTTP Basic Auth (empty = disabled)
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_CHAT_ID=

# Auto promote
AUTO_PROMOTE_ENABLED=false
AUTO_PROMOTE_VIDEO_RANGE_DAYS=30
AUTO_PROMOTE_VIDEO_COOLDOWN_SEC=60

# Aliyun MNS (message queue for async order creation)
MNS_ENDPOINT=
MNS_ACCESS_KEY_ID=
MNS_ACCESS_KEY_SECRET=
MNS_QUEUE_NAME=auto-promote-dev
